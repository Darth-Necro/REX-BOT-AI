# REX-BOT-AI Configuration
REX_MODE=basic
REX_LOG_LEVEL=info
# NOTE: REX_DATA_DIR is set by docker-compose.yml for container deploys.
# Only set this for bare-metal installs.
# REX_DATA_DIR=/etc/rex-bot-ai
REX_DASHBOARD_PORT=8443
REX_DASHBOARD_HOST=0.0.0.0

# Redis
# SECURITY: Change this password before first run! Generate with: openssl rand -base64 32
REDIS_PASSWORD=CHANGE_ME_BEFORE_FIRST_RUN
REDIS_URL=redis://localhost:6379

# Ollama (Local LLM)
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=auto

# ChromaDB (Vector Store)
CHROMA_URL=http://localhost:8000

# Network
REX_NETWORK_INTERFACE=auto
REX_SCAN_INTERVAL=300

# Notifications (configure in dashboard)
DISCORD_WEBHOOK_URL=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
NOTIFICATION_EMAIL=
MATRIX_HOMESERVER=
MATRIX_ROOM_ID=
MATRIX_ACCESS_TOKEN=
