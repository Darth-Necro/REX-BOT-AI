# REX-BOT-AI Configuration
REX_MODE=basic
REX_LOG_LEVEL=info
REX_DATA_DIR=/etc/rex-bot-ai
REX_DASHBOARD_PORT=8443
REX_DASHBOARD_HOST=0.0.0.0

# Redis
# SECURITY: Change this password before first run! Generate with: openssl rand -base64 32
# NOTE: REDIS_PASSWORD is used by Docker Compose to configure the Redis server.
# The REX app reads REX_REDIS_URL, which docker-compose.yml constructs automatically
# from REDIS_PASSWORD. For non-Docker dev, set REX_REDIS_URL directly.
REDIS_PASSWORD=CHANGE_ME_BEFORE_FIRST_RUN

# Ollama (Local LLM)
REX_OLLAMA_URL=http://localhost:11434
REX_OLLAMA_MODEL=auto

# ChromaDB (Vector Store)
REX_CHROMA_URL=http://localhost:8000

# Network
REX_NETWORK_INTERFACE=auto
REX_SCAN_INTERVAL=300

# Notifications (configure in dashboard)
DISCORD_WEBHOOK_URL=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
NOTIFICATION_EMAIL=
MATRIX_HOMESERVER=
MATRIX_ROOM_ID=
MATRIX_ACCESS_TOKEN=
